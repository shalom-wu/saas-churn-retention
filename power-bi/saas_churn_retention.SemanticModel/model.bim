          {
            "name": "mrr_lost_to_churn",
            "dataType": "double",
            "sourceColumn": "mrr_lost_to_churn",
            "summarizeBy": "none",
            "formatString": "$#,0"
          }
        ],
        "partitions": [
          {
            "name": "at_risk_segments",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\at_risk_segments.csv\"),[Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"segment\", type text}, {\"customers\", Int64.Type}, {\"churn_rate\", type number}, {\"mrr\", type number}, {\"mrr_lost_to_churn\", type number}})",
                "in",
                "    Typed"
              ]
            }
          }
        ]
      },
      {
        "name": "kpi_cost_of_churn",
        "columns": [
          {

            "formatString": "$#,0"
          },
          {
            "name": "avg_cost_per_churned_customer",
            "dataType": "double",
            "sourceColumn": "avg_cost_per_churned_customer",
            "summarizeBy": "none",
            "formatString": "$#,0"
          }
        ],
        "partitions": [
          {
            "name": "kpi_cost_of_churn",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(DataFolder & \"\\kpi_cost_of_churn.csv\"),[Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"churned_customers\", Int64.Type}, {\"lost_mrr\", type number}, {\"annualized_lost_revenue\", type number}, {\"foregone_ltv\", type number}, {\"replacement_cac_total\", type number}, {\"total_cost_of_churn\", type number}, {\"avg_cost_per_churned_customer\", type number}})",
                "in",
                "    Typed"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Cost of Churned Cohort",
            "expression": "MAX ( kpi_cost_of_churn[total_cost_of_churn] )",
            "formatString": "$#,##0.0,, \"M\""
          },
          {
            "name": "Annualized Lost Revenue",
            "expression": "MAX ( kpi_cost_of_churn[annualized_lost_revenue] )",
            "formatString": "$#,##0.0,, \"M\""
          }
        ]
      },
